{
  "backend": {
    "name": "github",
    "repo": "owner/repo",
    "branch": "main",
    "base_url": "https://test2.bvvbtrust.org",
    "auth_endpoint": "auth"
  },
  "media_folder": "assets/uploads",
  "collections": [
    {
      "name": "posts",
      "label": "Posts",
      "folder": "_posts",
      "create": true,
      "fields": [
        { "label": "Title", "name": "title", "widget": "string" },
        { "label": "Body", "name": "body", "widget": "markdown" }
      ]
    }
  ]
}
